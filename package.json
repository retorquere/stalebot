{
  "name": "stalebot",
  "version": "1.0.3",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts -o dist",
    "start": "npm run build",
    "pretest": "npm run build && npm run typecheck",
    "test": "dprint fmt src/index.ts",
    "typecheck": "tsc --noEmit",
    "preversion": "npm run build && npm run typecheck",
    "version": "git add dist",
    "postversion": "node scripts/sync-major-tag.js"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.44.1",
    "dprint": "^0.55.1",
    "typescript": "^5.9.2"
  }
}
